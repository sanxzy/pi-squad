{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"noEmit": true,
		"lib": ["ES2022"]
	},
	"include": ["*.ts"],
	"exclude": ["node_modules"]
}
